# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
# Optional: shared secret to verify requests to /api/telegram/webhook are from Telegram.
# Set the same value when calling setWebhook (secret_token param).
TELEGRAM_WEBHOOK_SECRET=

# AI Model (Google Gemini - free tier, get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key